# ========================
# VERITABANI (PostgreSQL)
# ========================
# Local için ayrı ayrı:
DB_NAME=UgaBurger
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# Production için (Railway vb.) tek satır:
# DATABASE_URL=postgresql://postgres:password@host:port/railway

# SSL kapatmak için (local):
DB_SSL=false

# ========================
# SUNUCU
# ========================
PORT=3000

# ========================
# JWT
# ========================
JWT_SECRET=uga_burger_super_secret_key_2026

# ========================
# CLIENT URL (CORS)
# ========================
CLIENT_URL=https://ugaburger.com

# ========================
# E-FATURA / E-ARSIV (Aktif Donusum)
# ========================
EINVOICE_PROVIDER=aktifdonusum
# API_MODE: "soap" (varsayilan) veya "rest". "rest" iken EINVOICE_REST_BASE_URL
# kullanilir, SOAP env'leri yok sayilir.
EINVOICE_API_MODE=rest
EINVOICE_REST_BASE_URL=https://portaltest.aktifdonusum.com/edonusum
EINVOICE_API_URL=https://service.aktifdonusum.com/InvoiceService/InvoiceWS
EINVOICE_WSDL_URL=https://service.aktifdonusum.com/InvoiceService/InvoiceWS?wsdl
EARCHIVE_API_URL=https://service.aktifdonusum.com/EArchiveInvoiceService/EArchiveInvoiceWS
EARCHIVE_WSDL_URL=https://service.aktifdonusum.com/EArchiveInvoiceService/EArchiveInvoiceWS?wsdl
EINVOICE_USERNAME=your_username
EINVOICE_PASSWORD=your_password
# Demo hesaba atanmis prefix (getPrefixCodeList ile dogrulanmistir)
EINVOICE_PREFIX=AEA
# Demo hesaba atanmis gonderici alias (queryUserAliasList ile dogrulanmistir)
EINVOICE_SOURCE_URN=urn:mail:defaultgb@aktif.com.tr
EINVOICE_SENDER_VKN=0102365158
EINVOICE_SENDER_TITLE=AHMET MUHITTIN ARK VE ULAS KANTARCI ADI ORTAKLIGI
EINVOICE_SENDER_TAX_OFFICE=Uray
EINVOICE_SENDER_ADDRESS=Inonu Mah. 1405 Sk. Murat Apt. No:2 B Yenisehir/Mersin
EINVOICE_SENDER_CITY=Mersin
EINVOICE_SENDER_DISTRICT=Yenisehir
EINVOICE_SENDER_POSTCODE=33000
EINVOICE_SENDER_EMAIL=info@ugaburger.com
EINVOICE_SENDER_PHONE=+905555555555
EINVOICE_TEST_MODE=true
EINVOICE_AUTO_SEND=true
EINVOICE_VAT_RATE=10
